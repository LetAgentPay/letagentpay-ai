{
  "name": "@letagentpay/ai",
  "version": "0.1.1",
  "description": "LetAgentPay tools for Vercel AI SDK — spending governance for AI agents",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "spending",
    "policy",
    "budget",
    "vercel",
    "ai-sdk",
    "tools",
    "governance",
    "letagentpay"
  ],
  "author": "LetAgentPay <hello@letagentpay.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/LetAgentPay/letagentpay-js",
    "directory": "packages/ai"
  },
  "homepage": "https://letagentpay.com",
  "bugs": {
    "url": "https://github.com/LetAgentPay/letagentpay-js/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "ai": ">=4.0.0",
    "zod": ">=3.0.0"
  },
  "dependencies": {
    "letagentpay": "^0.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ai": "^4.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "zod": "^3.24.0"
  }
}
